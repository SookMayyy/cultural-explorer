# ── Database (Supabase / PostgreSQL) ─────────────────────────────
# Supabase dashboard → Project Settings → Database → Connection string
# → "Session pooler" → URI. Replace [YOUR-PASSWORD] with your DB password
# (remove the square brackets). Put the real value in .env, NOT here —
# .env.example is committed to git.
DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Session ──────────────────────────────────────────────────────
# Use a long random string (min 32 chars), e.g. `openssl rand -hex 24`
SESSION_SECRET=change_this_to_a_long_random_string_min_32_chars

# ── ElevenLabs voice-over (npm run voiceover) ────────────────────
# Only needed to (re)generate mascot narration MP3s. Free tier = 10,000
# credits/month; the full script (~8.7k chars) fits with the default model.
# Get a key at elevenlabs.io → Profile → API Keys. Put the real key in .env only.
ELEVENLABS_API_KEY=
# Voice to narrate with — pick one from your ElevenLabs Voice Library and paste
# its Voice ID here. Leave blank to use the default (Rachel).
ELEVENLABS_VOICE_ID=
# eleven_turbo_v2_5 costs 0.5 credits/char (English, fast, good quality).
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# Optional pitch shift for a younger/child-like narrator (needs ffmpeg-static,
# already a dev dependency). 1 = off; 1.20 = +20% (raises pitch AND formants so
# the voice sounds younger/smaller). The current clips are Will
# (ELEVENLABS_VOICE_ID=bIHbv24MWmeRgasZH58o) at VO_PITCH=1.13.
VO_PITCH=1
