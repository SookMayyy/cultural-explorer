{
  "name": "cultural-explorer-malaysia",
  "version": "2.0.0",
  "description": "Game-Based Learning Platform for Malaysian Cultural Education — Primary School Students",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed": "node scripts/seed-content.mjs",
    "test": "jest --runInBand",
    "test:ui": "jest --config jest.ui.config.js --runInBand"
  },
  "keywords": [
    "malaysia",
    "culture",
    "education",
    "game",
    "learning",
    "primary-school"
  ],
  "author": "Phang Sook May (22074090) — Sunway University",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-session": "^1.18.0",
    "express-validator": "^7.1.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "puppeteer-core": "^24.43.1",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/ui/"
    ]
  }
}
